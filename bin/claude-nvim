#!/usr/bin/env node
/**
 * claude-nvim — launch Claude Code pre-connected to a running Neovim session.
 *
 * Port of nvim-aware-pi's `bin/pi-nvim`. Discovers the Neovim server (interactive
 * picker when several are running), changes into that instance's cwd, exports
 * NVIM_AWARE_SERVER so the plugin's hooks/MCP skip rediscovery, then execs `claude`.
 *
 * Wrapper flags (stripped before handing the rest to claude):
 *   --nvim-server <addr>     pin a specific Neovim server address
 *   --nvim-context <mode>    set NVIM_AWARE_PROMPT_CONTEXT (auto|full|hint|off)
 *
 * Symlink this onto your PATH (see README) and run `claude-nvim` instead of `claude`.
 */
import { spawn } from "node:child_process";
import { accessSync, constants, existsSync, realpathSync } from "node:fs";
import { stat } from "node:fs/promises";
import { basename, dirname, join, relative, resolve } from "node:path";
import { createInterface } from "node:readline";
import { fileURLToPath } from "node:url";
import { collectServerSummaries, chooseBestNvimServer } from "../lib/discover.mjs";
import { errorToMessage } from "../lib/proc.mjs";

const launchCwd = process.cwd();

main().catch((error) => {
	console.error(`claude-nvim: ${errorToMessage(error)}`);
	process.exit(1);
});

async function main() {
	const { claudeArgs, explicitServer, contextMode } = parseWrapperArgs(process.argv.slice(2));

	let selected;
	try {
		selected = await selectNvimServer({ explicitServer });
	} catch (error) {
		console.error(`claude-nvim: ${errorToMessage(error)}`);
	}

	if (selected?.cwd && (await isDirectory(selected.cwd))) {
		process.chdir(selected.cwd);
		console.error(`claude-nvim: connected to ${basename(selected.cwd) || selected.cwd} (${selected.server})`);
	} else if (selected?.server) {
		console.error(`claude-nvim: connected to ${selected.server}; staying in ${launchCwd}`);
	} else {
		console.error("claude-nvim: no Neovim server selected; starting Claude in the terminal cwd");
	}

	const realClaude = findRealClaude();
	const finalArgs = [...autoPluginDirArgs(), ...claudeArgs];
	const child = spawn(realClaude, finalArgs, {
		cwd: process.cwd(),
		stdio: "inherit",
		env: {
			...process.env,
			...(selected?.server ? { NVIM_AWARE_SERVER: selected.server } : {}),
			...(contextMode ? { NVIM_AWARE_PROMPT_CONTEXT: contextMode } : {}),
		},
	});

	child.on("error", (error) => {
		console.error(`claude-nvim: failed to start ${realClaude}: ${error.message}`);
		process.exit(1);
	});
	child.on("exit", (code, signal) => {
		if (signal) {
			process.kill(process.pid, signal);
			return;
		}
		process.exit(code ?? 1);
	});
}

function parseWrapperArgs(args) {
	const claudeArgs = [];
	let explicitServer;
	let contextMode;

	for (let i = 0; i < args.length; i++) {
		const arg = args[i];
		if (arg === "--nvim-server") {
			explicitServer = requireValue(args, ++i, "--nvim-server");
			continue;
		}
		if (arg.startsWith("--nvim-server=")) {
			explicitServer = arg.slice("--nvim-server=".length);
			continue;
		}
		if (arg === "--nvim-context") {
			contextMode = requireValue(args, ++i, "--nvim-context");
			continue;
		}
		if (arg.startsWith("--nvim-context=")) {
			contextMode = arg.slice("--nvim-context=".length);
			continue;
		}
		// Bare `--nvim` is just the opt-in trigger used by the shell wrapper; drop it
		// so it never reaches `claude`. `--nvim=<addr>` is a shorthand for the server.
		if (arg === "--nvim") {
			continue;
		}
		if (arg.startsWith("--nvim=")) {
			explicitServer = arg.slice("--nvim=".length);
			continue;
		}
		claudeArgs.push(arg);
	}

	return { claudeArgs, explicitServer, contextMode };
}

function requireValue(args, index, name) {
	const value = args[index];
	if (!value || value.startsWith("-")) throw new Error(`${name} requires a value`);
	return value;
}

async function selectNvimServer({ explicitServer }) {
	const { summaries } = await collectServerSummaries({ explicit: explicitServer });

	if (summaries.length === 0) {
		return explicitServer ? { server: explicitServer, cwd: undefined } : undefined;
	}
	if (explicitServer) {
		return summaries.find((s) => s.server === explicitServer) ?? summaries[0];
	}
	if (summaries.length === 1) {
		return summaries[0];
	}
	if (process.stdin.isTTY && process.stdout.isTTY) {
		return promptForServer(summaries);
	}

	const selected = chooseBestNvimServer(summaries, launchCwd);
	console.error(
		`claude-nvim: found ${summaries.length} Neovim instances; selected ${basename(selected.cwd) || selected.cwd}. Pass --nvim-server to choose explicitly.`,
	);
	return selected;
}

function promptForServer(summaries) {
	return new Promise((resolveChoice) => {
		const defaultSummary = chooseBestNvimServer(summaries, launchCwd);
		const defaultIndex = Math.max(0, summaries.indexOf(defaultSummary));
		const labels = labelledDirNames(summaries);
		const labelWidth = Math.max(...labels.map((label) => label.length));

		process.stdout.write("\nMultiple Neovim instances found.\n\n");
		summaries.forEach((summary, index) => {
			const marker = index === defaultIndex ? "*" : " ";
			const indexText = `${index + 1})`.padStart(String(summaries.length).length + 1, " ");
			process.stdout.write(`${marker} ${indexText} ${labels[index].padEnd(labelWidth)}  ${summary.cwd}  ${fileDisplay(summary)}\n`);
		});
		process.stdout.write("\n");

		const rl = createInterface({ input: process.stdin, output: process.stdout });
		const ask = () => {
			rl.question(`Connect to Neovim instance [1-${summaries.length}] (default ${defaultIndex + 1}): `, (answer) => {
				const trimmed = answer.trim();
				if (!trimmed) {
					rl.close();
					resolveChoice(defaultSummary);
					return;
				}
				const index = Number.parseInt(trimmed, 10);
				if (Number.isInteger(index) && index >= 1 && index <= summaries.length) {
					rl.close();
					resolveChoice(summaries[index - 1]);
					return;
				}
				process.stdout.write(`Please enter a number from 1 to ${summaries.length}.\n`);
				ask();
			});
		};
		ask();
	});
}

function labelledDirNames(summaries) {
	const counts = new Map();
	for (const summary of summaries) {
		const name = basename(summary.cwd) || summary.cwd;
		counts.set(name, (counts.get(name) ?? 0) + 1);
	}
	return summaries.map((summary) => {
		const name = basename(summary.cwd) || summary.cwd;
		if ((counts.get(name) ?? 0) <= 1) return name;
		const parent = basename(dirname(summary.cwd));
		return parent ? `${parent}/${name}` : name;
	});
}

function fileDisplay(summary) {
	if (!summary.currentFile) return "[No Name]";
	const rel = relative(summary.cwd, summary.currentFile);
	const file = rel && !rel.startsWith("..") && !rel.startsWith("/") ? rel : summary.currentFile;
	return summary.cursor?.line > 0 ? `${file}:${summary.cursor.line}` : file;
}

// Load the bundled plugin on demand (mirrors pi-nvim's auto `-e <extension>`), so
// nvim-awareness only happens when you go through this launcher. Skip when the user
// already installs the plugin globally (set NVIM_AWARE_AUTO_PLUGIN_DIR=0).
function autoPluginDirArgs() {
	const flag = process.env.NVIM_AWARE_AUTO_PLUGIN_DIR;
	if (flag === "0" || flag === "false") return [];
	const scriptPath = safeRealpath(fileURLToPath(import.meta.url));
	const pluginRoot = resolve(dirname(scriptPath), "..");
	if (!existsSync(join(pluginRoot, ".claude-plugin", "plugin.json"))) return [];
	return ["--plugin-dir", pluginRoot];
}

function findRealClaude() {
	if (process.env.NVIM_AWARE_REAL_CLAUDE) return process.env.NVIM_AWARE_REAL_CLAUDE;

	const current = safeRealpath(process.argv[1]);
	const names = process.platform === "win32" ? ["claude.cmd", "claude.exe", "claude"] : ["claude"];

	for (const dir of (process.env.PATH ?? "").split(process.platform === "win32" ? ";" : ":")) {
		if (!dir) continue;
		for (const name of names) {
			const candidate = join(dir, name);
			if (!isExecutable(candidate)) continue;
			if (safeRealpath(candidate) === current) continue;
			return candidate;
		}
	}
	return "claude";
}

async function isDirectory(path) {
	try {
		return (await stat(path)).isDirectory();
	} catch {
		return false;
	}
}

function isExecutable(path) {
	try {
		accessSync(path, constants.X_OK);
		return true;
	} catch {
		return false;
	}
}

function safeRealpath(path) {
	try {
		return realpathSync(path);
	} catch {
		return path;
	}
}
